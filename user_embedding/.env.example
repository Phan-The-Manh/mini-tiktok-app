# User Embedding Service — copy to .env (gitignored) and edit as needed.
#
# This service shares MongoDB + Redis with the Database Layer. By default we
# reuse database/.env via the _path shim, so you do NOT need to duplicate
# MONGO_URI / REDIS_URL here. Only override values below if you want this
# service to point at different infrastructure.

# --- HTTP service ---
USER_EMBEDDING_HOST=0.0.0.0
USER_EMBEDDING_PORT=8002

# --- Redis Streams consumer (user.action) ---
# Stream emitted by the Event Service (Component #8, built later). Until then
# the consumer is exercised with synthetic events in the smoke test.
USER_ACTION_STREAM=user.action
# Named consumer group; horizontal-scale by adding more workers in the same group.
USER_EMBEDDING_GROUP=user_embedding
# Per-process consumer name (override per replica when scaling).
USER_EMBEDDING_CONSUMER=worker-1
# Dead-letter list for messages that exceeded MAX_RETRIES.
USER_EMBEDDING_DLQ=user.action.dlq
# Max times a single message will be re-delivered before going to the DLQ.
USER_EMBEDDING_MAX_RETRIES=3
# How long XREADGROUP blocks (ms) waiting for new messages.
USER_EMBEDDING_BLOCK_MS=5000
# Idle time (ms) after which a pending message is reclaimed from a dead worker.
USER_EMBEDDING_CLAIM_IDLE_MS=60000

# --- Embedding math ---
# EMA retention for the short-term vector. new = decay*old + (1-decay)*weight*v.
# Higher = slower-moving / more history retained. 0.9 keeps ~90% of prior state
# per update, so a session shifts over several interactions rather than snapping.
USER_EMBEDDING_DECAY=0.9
# Blend of long-term vs short-term in the served query vector:
#   q = beta*long + (1-beta)*short. 0.5 = equal weight.
USER_EMBEDDING_BLEND_BETA=0.5
# Redis cache TTL (seconds) for a user's cached vectors.
USER_EMBEDDING_CACHE_TTL=86400
# Window (days) of interactions used by the long-term recompute batch.
USER_EMBEDDING_LONGTERM_WINDOW_DAYS=30
