# Content Analyzer — copy to .env (gitignored) and edit as needed.
#
# The Content Analyzer shares MongoDB, Redis, and MinIO with the Database
# Layer. By default we reuse database/.env via the _path shim, so you do NOT
# need to duplicate MONGO_URI / REDIS_URL / MINIO_* here. Only override
# values below if you want the analyzer to point at different infrastructure.

# --- Redis Streams consumer ---
# Stream emitted by the Upload Service (Component #2).
CONTENT_ANALYZER_STREAM=video.uploaded
# Named consumer group; horizontal-scale by adding more workers in the same group.
CONTENT_ANALYZER_GROUP=content_analyzer
# Per-process consumer name (override per replica when scaling).
CONTENT_ANALYZER_CONSUMER=worker-1
# Dead-letter list for messages that exceeded MAX_RETRIES.
CONTENT_ANALYZER_DLQ=video.uploaded.dlq
# Max times a single message will be re-delivered before going to the DLQ.
CONTENT_ANALYZER_MAX_RETRIES=3
# How long XREADGROUP blocks (ms) waiting for new messages.
CONTENT_ANALYZER_BLOCK_MS=5000

# --- Analyzer config ---
# Bumping this triggers re-embedding on the next delivery (idempotency key).
ANALYZER_VERSION=v1
# Number of evenly-spaced frames sampled from each video.
ANALYZER_FRAME_COUNT=8
# Where temp files (downloaded video, extracted frames, wav) live.
# Leave blank to use the OS default temp dir.
ANALYZER_TEMP_DIR=

# --- Model choices ---
# CLIP visual encoder (HuggingFace model id).
CLIP_MODEL=openai/clip-vit-base-patch32
# Whisper transcription model. `tiny` is CPU-friendly (~39M params).
WHISPER_MODEL=tiny
# Sentence embedding model for caption + transcript.
TEXT_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- External binaries ---
# ffmpeg is used for frame sampling and audio extraction. Must be on PATH
# or set the absolute path here.
FFMPEG_BIN=ffmpeg
