# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# --- MongoDB Atlas (cloud, free M0 tier) ---
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Then create a database user and paste its SRV connection string here.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=mini-tiktok
MONGO_DB_NAME=mini_tiktok

# --- Redis (local Docker, started by docker-compose.yml) ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO (local Docker, S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=videos
MINIO_SECURE=false
