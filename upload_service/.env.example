# Upload Service — copy to .env (gitignored) and edit as needed.
#
# The Upload Service shares MongoDB, Redis, and MinIO with the Database Layer.
# By default we reuse database/.env via the _path shim, so you do NOT need to
# duplicate MONGO_URI / REDIS_URL / MINIO_* here. Only override values below
# if you want the upload service to point at different infrastructure.

# --- Service config ---
UPLOAD_SERVICE_HOST=0.0.0.0
UPLOAD_SERVICE_PORT=8001

# --- Storage ---
# Bucket the upload service writes to. Auto-created on startup if missing.
MINIO_BUCKET=videos
MINIO_THUMBNAIL_BUCKET=thumbnails
# Public URL prefix used when building Video.url for clients.
# In local dev MinIO serves on http://localhost:9000.
MINIO_PUBLIC_URL=http://localhost:9000

# --- Transcoding ---
# If "true", run ffmpeg to normalize uploads to mp4/h264 and extract a thumbnail.
# If "false" (or ffmpeg is missing), uploads are stored as-is and thumbnails are skipped.
ENABLE_TRANSCODE=true
FFMPEG_BIN=ffmpeg

# --- Event bus ---
# Redis Stream key the Content Analyzer will consume.
UPLOAD_EVENT_STREAM=video.uploaded
